# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Consumed by docker-compose / postgres.sh for local development.
# In production, inject these via your secret manager, NOT a committed file.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=meal_plan_db

# Spring Boot datasource (read by application.yml via ${...} placeholders)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/meal_plan_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

# JWT signing key
# Generate a new one with:
#   openssl rand -base64 32
# Must be at least 256 bits (32 bytes) for HS256.
JWT_SECRET=replace-with-a-base64-encoded-256-bit-key
JWT_EXPIRATION_MS=86400000
